---
import { siteConfig } from '@data/site';

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-lg border-b border-gray-200 dark:border-slate-700 animate-slideInLeft shadow-sm">
  <div class="container">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="text-2xl font-bold text-gradient hover:scale-110 transition-all duration-300">
        {siteConfig.name}
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {siteConfig.navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-all duration-300 hover:text-primary-600 relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-primary-600 after:transition-all after:duration-300 hover:after:w-full',
              currentPath === item.href ? 'text-primary-600 after:w-full' : 'text-gray-600 dark:text-gray-300'
            ]}
          >
            {item.name}
          </a>
        ))}

        <div class="inline-flex items-center gap-3">
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Tema</span>
          <button
            id="theme-toggle-desktop"
            data-theme-toggle
            type="button"
            role="switch"
            aria-checked="false"
            aria-label="Ganti tema"
            title="Ganti tema"
            class="relative inline-flex h-8 w-14 items-center rounded-full border border-gray-300 dark:border-slate-600 bg-gray-300 transition-colors duration-300"
          >
            <span class="sr-only">Toggle dark mode</span>
            <span class="absolute left-2 text-[10px] leading-none" aria-hidden="true">☀️</span>
            <span class="absolute right-2 text-[10px] leading-none" aria-hidden="true">🌙</span>
            <span
              data-theme-thumb
              class="absolute left-1 top-1 h-6 w-6 rounded-full bg-white shadow-md transition-transform duration-300"
            ></span>
          </button>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden flex items-center gap-2">
        <button
          id="theme-toggle-mobile"
          data-theme-toggle
          type="button"
          role="switch"
          aria-checked="false"
          class="relative inline-flex h-7 w-12 items-center rounded-full border border-gray-300 dark:border-slate-600 bg-gray-300 transition-colors duration-300"
          aria-label="Ganti tema"
          title="Ganti tema"
        >
          <span class="sr-only">Toggle dark mode</span>
          <span
            data-theme-thumb
            class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white shadow transition-transform duration-300"
          ></span>
        </button>

        <button
          id="mobile-menu-button"
          class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6 text-gray-800 dark:text-gray-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 dark:border-slate-700">
    <div class="container py-4 space-y-3">
      {siteConfig.navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-4 py-2 rounded-lg text-sm font-medium transition-colors',
            currentPath === item.href
              ? 'bg-primary-50 text-primary-600'
              : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-800'
          ]}
        >
          {item.name}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const themeStorageKey = 'theme-preference';
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const themeToggles = Array.from(document.querySelectorAll('[data-theme-toggle]'));
  const themeThumbs = Array.from(document.querySelectorAll('[data-theme-thumb]'));

  const setTheme = (theme) => {
    const isDark = theme === 'dark';
    document.documentElement.classList.toggle('dark', isDark);
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem(themeStorageKey, theme);

    themeToggles.forEach((toggle) => {
      toggle.setAttribute('aria-checked', isDark ? 'true' : 'false');
      toggle.classList.toggle('bg-primary-600', isDark);
      toggle.classList.toggle('bg-gray-300', !isDark);
    });

    themeThumbs.forEach((thumb) => {
      const isMobile = thumb.classList.contains('h-5');
      thumb.classList.toggle('translate-x-5', isDark && isMobile);
      thumb.classList.toggle('translate-x-6', isDark && !isMobile);
      thumb.classList.toggle('translate-x-0', !isDark);
    });
  };

  const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
  setTheme(currentTheme);

  themeToggles.forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const nextTheme = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
      setTheme(nextTheme);
    });
  });

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
