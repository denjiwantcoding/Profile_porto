---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Portfolio', description = 'Website portofolio profesional' } = Astro.props;

import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import ScrollReveal from '@components/ScrollReveal.astro';
import CollaborativeAnimation from '@components/CollaborativeAnimation.astro';
import { siteConfig } from '@data/site';

const pageTitle = title ? `${title} | ${siteConfig.name}` : siteConfig.title;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="color-scheme" content="light dark">
  <meta name="generator" content={Astro.generator}>
  <script is:inline>
    (() => {
      const storageKey = 'theme-preference';
      const savedTheme = localStorage.getItem(storageKey);
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = savedTheme || (systemPrefersDark ? 'dark' : 'light');

      document.documentElement.classList.toggle('dark', theme === 'dark');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={description}>
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:title" content={pageTitle}>
  <meta property="twitter:description" content={description}>
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  
  <title>{pageTitle}</title>
</head>
<body class="min-h-screen flex flex-col transition-colors duration-300">
  <!-- Collaborative Animation Effects -->
  <CollaborativeAnimation />
  
  <Navbar />
  
  <main class="flex-grow">
    <slot />
  </main>
  
  <Footer />
  
  <!-- Scroll Reveal Component -->
  <ScrollReveal />

  <script>
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  </script>
</body>
</html>
